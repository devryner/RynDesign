{
  "name": "@ryndesign/cli",
  "version": "0.2.0",
  "description": "CLI for RynDesign design system generator",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devryner/RynDesign.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "ryndesign": "./dist/bin.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ryndesign/core": "workspace:*",
    "@ryndesign/plugin-api": "workspace:*",
    "citty": "^0.1.6",
    "@clack/prompts": "^0.8.0",
    "picocolors": "^1.1.0",
    "jiti": "^2.4.0",
    "chokidar": "^4.0.0",
    "fast-glob": "^3.3.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "~5.5.0",
    "vitest": "^2.1.0"
  }
}
