{
  "name": "@ryndesign/generator-react",
  "version": "0.1.0",
  "description": "React generator plugin for RynDesign",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ryndesign/plugin-api": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "~5.5.0",
    "vitest": "^2.1.0"
  }
}
