{
  "name": "@ryndesign/preview",
  "version": "0.1.3",
  "description": "Preview server for RynDesign design system",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devryner/RynDesign.git",
    "directory": "packages/preview"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "client"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ryndesign/core": "workspace:*",
    "@ryndesign/plugin-api": "workspace:*",
    "@vitejs/plugin-react": "^6.0.1",
    "chokidar": "^4.0.0",
    "fast-glob": "^3.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^8.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.0",
    "tsup": "^8.3.0",
    "typescript": "~5.5.0",
    "vitest": "^2.1.0"
  }
}
