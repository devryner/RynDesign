{
  "name": "@ryndesign/preview",
  "version": "0.1.0",
  "description": "Preview server for RynDesign design system",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist", "client"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ryndesign/core": "workspace:*",
    "@ryndesign/plugin-api": "workspace:*",
    "vite": "^6.0.0",
    "ws": "^8.18.0",
    "chokidar": "^4.0.0",
    "fast-glob": "^3.3.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "tsup": "^8.3.0",
    "typescript": "~5.5.0",
    "vitest": "^2.1.0"
  }
}
