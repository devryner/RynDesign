{
  "name": "@ryndesign/plugin-api",
  "version": "0.1.1",
  "description": "Plugin API interfaces for RynDesign design system generator",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devryner/RynDesign.git",
    "directory": "packages/plugin-api"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "~5.5.0"
  }
}
